# Server
NODE_ENV=development
PORT=4000

# CORS — comma-separated list of allowed origins (use * to allow all in dev)
CORS_ORIGIN=*

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# (local trust auth needs no password: postgresql://postgres@localhost:5432/taskflow?schema=public)
DATABASE_URL="postgresql://postgres@localhost:5432/taskflow?schema=public"

# --- Auth ---
# Secret used to sign access-token JWTs. MUST be >= 32 chars. Generate: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
# Access-token lifetime (jsonwebtoken/ms format, e.g. 15m, 1h)
JWT_ACCESS_TTL=15m
# Refresh-token lifetime in days
REFRESH_TOKEN_TTL_DAYS=30
# bcrypt cost factor (10-15)
BCRYPT_ROUNDS=12
# Cookie name carrying the refresh token
REFRESH_COOKIE_NAME=refresh_token

# --- Logging ---
# pino level: fatal|error|warn|info|debug|trace|silent. Optional.
# Defaults: silent in test, info otherwise.
# LOG_LEVEL=info

# --- Cache (Redis) ---
REDIS_URL=redis://localhost:6379
CACHE_ENABLED=true
CACHE_TTL_SECONDS=300
